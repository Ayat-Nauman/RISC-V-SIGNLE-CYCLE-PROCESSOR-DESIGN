module main_decoder (
input logic [6:0] opcode,
output logic RegWrite, MemWrite, branch, resultSrc, ALUsrc,
output logic [1:0] ImmSrc, ALUop
);


always_comb begin
case (opcode_enum)

//LW - load word
0000011: begin 
	RegWrite = 1'b1;
	ImmSrc = 2'b00;
	ALUsrc = 1'b0;
	MemWrite = 1'b0; 
	resultSrc = 1'b1;
	branch = 1'b0; 
	ALUop = 2'b00;
	
end

//SW - Store word
0100011: begin
	RegWrite = 1'b0;
	ImmSrc = 2'b01;
	ALUsrc = 1'b1;
	MemWrite = 1'b1; 
	resultSrc = 1'bx;
	branch = 1'b0; 
	ALUop = 2'b00;
	
end

// R-type
0110011: begin
	RegWrite = 1'b1;
	ImmSrc = 2'bxx;
	ALUsrc = 1'b0;
	MemWrite = 1'b0; 
	resultSrc = 1'b0;
	branch = 1'b0; 
	ALUop = 2'b10;
	
end

// BEQ - Branch if Equal
1100011: begin
	RegWrite = 1'b0;
	ImmSrc = 2'b10;
	ALUsrc = 1'b0;
	MemWrite = 1'b0; 
	resultSrc = 1'bx;
	branch = 1'b1; 
	ALUop = 2'b01;
	
end

endcase
end 

endmodule
